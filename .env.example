# DBA ChangeOps AI 工作台示例配置
#
# 本地试运行可以保持 DATABASE_URL 和 LLM_API_KEY 为空。
# 应用会自动使用本机用户数据目录下的 SQLite，并启用离线兜底。
# 面试现场如需完全避免本机 SQLite 文件权限或路径问题，可以临时设置：
# DATABASE_URL=sqlite:///:memory:

APP_ENV=development

# 本地可留空；云部署必须配置托管 PostgreSQL，例如：
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=

# OpenAI-compatible Chat Completions 服务。
# 通义千问兼容模式示例：
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# 留空时进入离线兜底模式；配置后会调用真实模型。
LLM_API_KEY=

# 云部署最小可用配置参考：
#
# APP_ENV=production
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus
# LLM_API_KEY=
#
# 第一版公开演示建议先让 LLM_API_KEY 留空，确保线上地址、数据库、
# 交付闭环、审计、签收和导出稳定可用；真实模型 Key 可以之后再加。
